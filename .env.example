# OpenAI-compatible API endpoint and key
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-5.4
LLM_FALLBACK_MODEL=
LLM_TEXT_ENDPOINT=chat_completions
LLM_SUPPORTS_VISION_INPUT=true
LLM_VISION_MODEL=

# Example for a proxy that exposes a compat-only model name plus a Responses fallback:
# LLM_MODEL=cc-gpt-5.4
# LLM_FALLBACK_MODEL=gpt-5.4
# LLM_TEXT_ENDPOINT=responses

