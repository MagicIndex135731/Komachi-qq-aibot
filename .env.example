NAPCAT_WS_URL=ws://127.0.0.1:3001

# Main text chat provider.
# If your provider base URL already ends with /v1, keep LLM_TEXT_ENDPOINT as /chat/completions.
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEXT_ENDPOINT=/chat/completions
LLM_API_KEY=replace-me
LLM_MODEL=gpt-5.4

# Group image generation provider.
# Leave GROUP_IMAGE_BASE_URL and GROUP_IMAGE_API_KEY blank to reuse LLM_BASE_URL and LLM_API_KEY.
# Use /images/generations for prompt-to-image and /images/edits for reference-image redraw/edit flows.
GROUP_IMAGE_BASE_URL=
GROUP_IMAGE_API_KEY=
GROUP_IMAGE_MODEL=gpt-image-2
GROUP_IMAGE_GENERATIONS_ENDPOINT=/images/generations
GROUP_IMAGE_EDITS_ENDPOINT=/images/edits
GROUP_IMAGE_SIZE=auto
GROUP_IMAGE_QUALITY=high
GROUP_IMAGE_BACKGROUND=
GROUP_IMAGE_OUTPUT_FORMAT=png
GROUP_IMAGE_OUTPUT_COMPRESSION=100
GROUP_IMAGE_MODERATION=low
GROUP_IMAGE_QUEUE_CAPACITY=3

# QQ identity and permissions.
BOT_QQ=123456789
# OWNER_QQ is always allowed for private chat and can enter project admin mode.
OWNER_QQ=987654321
# Extra admin QQs, comma-separated. These QQs can use whitelist admin commands like /bot status.
ADMIN_QQS=
# Extra private-chat QQs, comma-separated. OWNER_QQ is auto-included.
# Add a QQ here if you want the bot to accept private chat from that user.
PRIVATE_CHAT_QQS=

# Search configuration.
# SEARCH_PROVIDER=ddgs can work without SEARCH_API_KEY.
# SEARCH_PROVIDER=tavily requires SEARCH_API_KEY.
SEARCH_PROVIDER=ddgs
SEARCH_BASE_URL=https://api.tavily.com/search
SEARCH_API_KEY=
SEARCH_TIMEOUT_SECONDS=8
SEARCH_REGION=wt-wt
SEARCH_BACKEND=auto

# Conversation context limits.
CONTEXT_RECENT_LIMIT=60
CONTEXT_SUMMARY_LIMIT=3
CONTEXT_HISTORY_LIMIT=8

# Optional local Windows path overrides.
# Fill these only if the launcher cannot find QQ or NapCat automatically.
QQ_EXE_PATH=
NAPCAT_SHELL_DIR=
NAPCAT_BOOT_PATH=
NAPCAT_INJECT_DLL_PATH=
NAPCAT_WAIT_TIMEOUT_SECONDS=180
