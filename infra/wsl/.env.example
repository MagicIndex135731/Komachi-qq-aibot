# Copy this file to infra/wsl/.env and fill the required local secrets.
# Do not commit infra/wsl/.env.

TZ=Asia/Shanghai
QQ_PLATFORM=llbot
LLBOT_WEBUI_PORT=3080
LLBOT_WS_PORT=3002

# OneBot websocket inside docker network.
NAPCAT_WS_URL=ws://napcat:3001
NAPCAT_HTTP_PORT=6099
NAPCAT_WS_PORT=3001

# Optional NapCat login fallback.
# Keep these empty in git. Set only in infra/wsl/.env if you want NapCat to
# try password login when the persisted QQ login state expires.
NAPCAT_QUICK_PASSWORD=
NAPCAT_QUICK_PASSWORD_MD5=

# Fill with the watched group id used by Xiaomachi's group stream probe.
GROUP_STREAM_WATCH_GROUP_ID=
GROUP_STREAM_MAX_LAG_SECONDS=1800

# Existing Xiaomachi runtime options should be copied from the Windows .env.
ONEBOT_PROBE_STARTUP_GRACE_SECONDS=180
XIAOMACHI_FULL_RESTART_COOLDOWN_SECONDS=600

# API keys and model settings must be provided in infra/wsl/.env only.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5.6-terra
LLM_TEXT_ENDPOINT=responses
LLM_REASONING_EFFORT=medium
LLM_CONTEXT_WINDOW_TOKENS=258000
LLM_MAX_OUTPUT_TOKENS=8192
LLM_CONTEXT_SAFETY_MARGIN_TOKENS=32768
LLM_TOOL_CONTEXT_RESERVE_TOKENS=32768
CONTEXT_RECENT_LIMIT=100
CONTEXT_SUMMARY_LIMIT=3
CONTEXT_HISTORY_LIMIT=8

# Durable semantic memory compaction and startup backfill.
MEMORY_COMPACTION_ENABLED=true
MEMORY_COMPACTION_BATCH_SIZE=50
MEMORY_COMPACTION_MAX_FACTS=24
MEMORY_COMPACTION_RETRY_LIMIT=3
MEMORY_COMPACTION_BACKFILL_WINDOWS=24

# Memory Orchestration V2 starts in shadow mode: V1 remains the live prompt
# while V2 only records safe retrieval metrics. Keep API keys empty in this
# example; local FastEmbed uses the persistent /workspace/data volume cache.
MEMORY_ORCHESTRATION_V2_ENABLED=true
MEMORY_ORCHESTRATION_SHADOW_MODE=true
MEMORY_EMBEDDING_PROVIDER=local
MEMORY_EMBEDDING_DEVICE=auto
MEMORY_EMBEDDING_LOCAL_FILES_ONLY=false
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
MEMORY_EMBEDDING_DIMENSIONS=512
MEMORY_EMBEDDING_CACHE_DIR=/workspace/data/models
MEMORY_EMBEDDING_BASE_URL=
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_VERSION=
MEMORY_EMBEDDING_TIMEOUT_SECONDS=10
MEMORY_RETRIEVAL_CHANNEL_TIMEOUT_SECONDS=2
MEMORY_EPISODE_IDLE_MINUTES=30
MEMORY_EPISODE_MAX_MESSAGES=50
MEMORY_EPISODE_MAX_TOKENS=8000
MEMORY_CHUNK_MAX_TOKENS=1800
MEMORY_CHUNK_OVERLAP_MESSAGES=5
MEMORY_QUERY_REWRITE_ENABLED=false
MEMORY_QUERY_REWRITE_TIMEOUT_SECONDS=3
MEMORY_QUERY_REWRITE_MAX_OUTPUT_TOKENS=256
MEMORY_LLM_RERANK_ENABLED=false
MEMORY_NORMAL_CONTEXT_BUDGET_TOKENS=32000
MEMORY_DETAIL_CONTEXT_BUDGET_TOKENS=64000
MEMORY_RECENT_CONTEXT_BUDGET_TOKENS=10000
MEMORY_FTS_CANDIDATE_LIMIT=30
MEMORY_VECTOR_CANDIDATE_LIMIT=30
MEMORY_FINAL_EPISODE_LIMIT=6

# Optional external search provider used when built-in model search is unavailable.
SEARCH_PROVIDER=tavily
SEARCH_BASE_URL=https://api.tavily.com/search
SEARCH_API_KEY=

# Group/private image generation uses its own OpenAI-compatible image endpoint.
# Keep this key separate from LLM_API_KEY; it is used only for image generation and edits.
GROUP_IMAGE_BASE_URL=
GROUP_IMAGE_API_KEY=
GROUP_IMAGE_MODEL=gpt-image-2
GROUP_IMAGE_GENERATIONS_ENDPOINT=/images/generations
GROUP_IMAGE_EDITS_ENDPOINT=/images/edits
GROUP_IMAGE_SIZE=auto
GROUP_IMAGE_QUALITY=high
GROUP_IMAGE_OUTPUT_FORMAT=png
GROUP_IMAGE_QUEUE_CAPACITY=3
GROUP_IMAGE_TIMEOUT_SECONDS=900

# Optional: proxy used by Docker containers when downloading Python dependencies.
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_NO_PROXY=localhost,127.0.0.1,napcat,xiaomachi,host.docker.internal
PIP_DEFAULT_TIMEOUT=120
PIP_RETRIES=10
PIP_INDEX_URL=
