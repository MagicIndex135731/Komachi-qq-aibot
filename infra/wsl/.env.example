# Copy this file to infra/wsl/.env and fill the required local secrets.
# Do not commit infra/wsl/.env.

TZ=Asia/Shanghai
QQ_PLATFORM=llbot
LLBOT_WEBUI_PORT=3080
LLBOT_WS_PORT=3002

# OneBot websocket inside docker network.
NAPCAT_WS_URL=ws://napcat:3001
NAPCAT_HTTP_PORT=6099
NAPCAT_WS_PORT=3001

# Optional NapCat login fallback.
# Keep these empty in git. Set only in infra/wsl/.env if you want NapCat to
# try password login when the persisted QQ login state expires.
NAPCAT_QUICK_PASSWORD=
NAPCAT_QUICK_PASSWORD_MD5=

# Fill with the watched group id used by Xiaomachi's group stream probe.
GROUP_STREAM_WATCH_GROUP_ID=
GROUP_STREAM_MAX_LAG_SECONDS=1800

# Existing Xiaomachi runtime options should be copied from the Windows .env.
ONEBOT_PROBE_STARTUP_GRACE_SECONDS=180
XIAOMACHI_FULL_RESTART_COOLDOWN_SECONDS=600

# API keys and model settings must be provided in infra/wsl/.env only.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5.6-terra
LLM_TEXT_ENDPOINT=responses
LLM_REASONING_EFFORT=medium
LLM_CONTEXT_WINDOW_TOKENS=258000
LLM_MAX_OUTPUT_TOKENS=8192
LLM_CONTEXT_SAFETY_MARGIN_TOKENS=32768
LLM_TOOL_CONTEXT_RESERVE_TOKENS=32768

# Group/private image generation uses its own OpenAI-compatible image endpoint.
# Keep this key separate from LLM_API_KEY; it is used only for image generation and edits.
GROUP_IMAGE_BASE_URL=
GROUP_IMAGE_API_KEY=
GROUP_IMAGE_MODEL=gpt-image-2
GROUP_IMAGE_GENERATIONS_ENDPOINT=/images/generations
GROUP_IMAGE_EDITS_ENDPOINT=/images/edits
GROUP_IMAGE_SIZE=auto
GROUP_IMAGE_QUALITY=high
GROUP_IMAGE_OUTPUT_FORMAT=png
GROUP_IMAGE_QUEUE_CAPACITY=3
GROUP_IMAGE_TIMEOUT_SECONDS=900

# Optional: proxy used by Docker containers when downloading Python dependencies.
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_NO_PROXY=localhost,127.0.0.1,napcat,xiaomachi,host.docker.internal
PIP_DEFAULT_TIMEOUT=120
PIP_RETRIES=10
PIP_INDEX_URL=
