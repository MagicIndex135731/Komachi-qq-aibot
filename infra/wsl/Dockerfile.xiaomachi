FROM python:3.12-slim

ARG PIP_DEFAULT_TIMEOUT=120
ARG PIP_RETRIES=10
ARG PIP_INDEX_URL
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

COPY infra/wsl/requirements.xiaomachi.txt ./

RUN python -m pip install -U pip setuptools wheel \
    && python -m pip install -r requirements.xiaomachi.txt

COPY app ./app
COPY configs ./configs

CMD ["python", "-m", "app.group_main"]
